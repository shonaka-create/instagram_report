# Google Sheets転記(export_report)用のサービスアカウント認証情報
# GCPコンソール → サービスアカウント作成 → JSONキーから client_email と private_key を転記
# private_key は改行を \n のままコピーしてOK(コード側で復元する)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# clients.json の場所を変えたい場合のみ設定(省略時は mcp-server/clients.json)
# CLIENTS_FILE=C:\path\to\clients.json
