# デプロイ先URL(末尾スラッシュなし)。QStashのコールバック先になる
APP_URL=https://your-app.vercel.app

# Vercel Cron の認証用。openssl rand -hex 32 等で生成し、Vercelの環境変数にも設定
CRON_SECRET=

# Supabase (Project Settings → API)
SUPABASE_URL=https://nffprofzjzvkxsxyegdq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Upstash QStash (Console → QStash)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# PDFファイル生成(wants_pdf=trueのクライアントがいる場合のみ必要)
# Supabase Storageのpublicバケット(bin)に置いたchromiumパックのURL
# 例: https://xxxx.supabase.co/storage/v1/object/public/bin/chromium-v138.0.2-pack.x64.tar
CHROMIUM_PACK_URL=
