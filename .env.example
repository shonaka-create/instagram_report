# デプロイ先URL(末尾スラッシュなし)。MCPのpublish_reportが発行するURLの起点
APP_URL=https://your-app.vercel.app

# サイト全体の閲覧パスワード(社内用)。未設定だと本番では503になる(閉め忘れ防止)
SITE_PASSWORD=

# Vercel Cron の認証用。openssl rand -hex 32 等で生成し、Vercelの環境変数にも設定
CRON_SECRET=

